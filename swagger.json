{
	"openapi": "3.0.0",
	"info": {
		"title": "Contacts API",
		"description": "API for CSE341 Assignment",
		"version": "1.1.0"
	},
	"servers": [
		{
			"url": "http://localhost:8080",
			"description": "Local development"
		},
		{
			"url":"https://cse341-node-cbto.onrender.com",
			"description": "Production"
		}
	],
	"paths": {
		"/contacts": {
			"get": {
				"description": "Retrieve all contacts",
				"tags": ["Contacts"],
				"responses": {
					"200": {
						"description": "OK",
						"content": {
							"application/json": {
								"schema": {
									"type": "object",
									"properties": {
										"message": { "type": "string" },
										"contacts": {
											"type": "array",
											"items": {
												"$ref": "#/components/schemas/Contact"
											}
										}
									}
								}
							}
						}
					},
					"500": {
						"description": "Internal Server Error"
					}
				}
			},
			"post": {
				"description": "Create a new contact",
				"tags": ["Contacts"],
				"requestBody": {
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/Contact"
							}
						}
					}
				},
				"responses": {
					"201": {
						"description": "Created",
						"content": {
							"application/json": {
								"schema": {
									"type": "object",
									"properties": {
										"message": { "type": "string" },
										"contactId": { "type": "string" }
									}
								}
							}
						}
					},
					"400": {
						"description": "Bad Request"
					},
					"500": {
						"description": "Internal Server Error"
					}
				}
			}
		},
		"/contacts/{id}": {
			"get": {
				"description": "Retrieve a contact by ID",
				"tags": ["Contacts"],
				"parameters": [
					{
						"name": "id",
						"in": "path",
						"required": true,
						"schema": { "type": "string" }
					}
				],
				"responses": {
					"200": {
						"description": "OK",
						"content": {
							"application/json": {
								"schema": {
									"type": "object",
									"properties": {
										"message": { "type": "string" },
										"contact": {
											"$ref": "#/components/schemas/Contact"
										}
									}
								}
							}
						}
					},
					"500": {
						"description": "Internal Server Error"
					}
				}
			},
			"put": {
				"description": "Update a contact by ID",
				"tags": ["Contacts"],
				"parameters": [
					{
						"name": "id",
						"in": "path",
						"required": true,
						"schema": { "type": "string" }
					}
				],
				"requestBody": {
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/Contact"
							}
						}
					}
				},
				"responses": {
					"200": {
						"description": "OK"
					},
					"404": {
						"description": "Not Found"
					},
					"500": {
						"description": "Internal Server Error"
					}
				}
			},
			"delete": {
				"description": "Delete a contact by ID",
				"tags": ["Contacts"],
				"parameters": [
					{
						"name": "id",
						"in": "path",
						"required": true,
						"schema": { "type": "string" }
					}
				],
				"responses": {
					"200": {
						"description": "OK"
					},
					"404": {
						"description": "Not Found"
					},
					"500": {
						"description": "Internal Server Error"
					}
				}
			}
		}
	},
	"components": {
		"schemas": {
			"Contact": {
				"type": "object",
				"required": [
					"firstName",
					"lastName",
					"email",
					"favoriteColor",
					"birthday"
				],
				"properties": {
					"firstName": {
						"type": "string",
						"example": "John"
					},
					"lastName": {
						"type": "string",
						"example": "Doe"
					},
					"email": {
						"type": "string",
						"example": "johndoe@example.com"
					},
					"favoriteColor": {
						"type": "string",
						"example": "Blue"
					},
					"birthday": {
						"type": "string",
						"format": "date",
						"example": "1980-01-01"
					}
				}
			}
		}
	}
}
